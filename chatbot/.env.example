# Database Configuration
# For PostgreSQL (Primary recommendation for persistent memory & full-text search):
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/ai_chatbot_db

# For local zero-setup testing without Docker or Postgres installed right now, you can also uncomment SQLite:
# DATABASE_URL=sqlite:///./ai_chatbot.db

# Ollama LLM Configuration
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT=120

# JWT & Security
SECRET_KEY=super-secret-jwt-key-change-this-in-production-2026
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Memory & Summarization Settings
SUMMARIZATION_MESSAGE_THRESHOLD=30
RECENT_MESSAGES_WINDOW=10
